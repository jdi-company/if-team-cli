{
  "name": "@jdi/if-team-cli",
  "version": "0.1.0",
  "description": "TypeScript CLI for if-team",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "if-team": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "if-team",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdi-company/if-team-cli.git"
  },
  "bugs": {
    "url": "https://github.com/jdi-company/if-team-cli/issues"
  },
  "preferGlobal": true,
  "engines": {
    "node": ">=20.18.1"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "chalk": "5.4.1",
    "commander": "14.0.3",
    "ora": "8.2.0"
  },
  "devDependencies": {
    "@types/node": "22.15.21",
    "typescript": "5.8.3",
    "vitest": "3.1.4"
  }
}
