{
  "name": "if-team-cli",
  "version": "1.0.0",
  "description": "TypeScript CLI for if.team",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "if-team": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:skill": "npm run build && node scripts/sync-skill.js",
    "check:skill-sync": "npm run build && node scripts/check-skill-sync.js",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "if-team",
    "if.team",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdi-company/if-team-cli.git"
  },
  "bugs": {
    "url": "https://github.com/jdi-company/if-team-cli/issues"
  },
  "preferGlobal": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "scripts/postinstall.js"
  ],
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^24.12.4",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
